# ──────────────────────────────────────────
# ICDAR 2026 DocVQA — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ──────────────────────────────────────────

# REQUIRED: HuggingFace token for downloading gated models (Qwen, Gemma)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE

# OPTIONAL: Weights & Biases for experiment tracking
# Get yours at: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=docvqa2026
WANDB_ENTITY=your_wandb_username

# OPTIONAL: Cache directory overrides
HF_DATASETS_CACHE=data/raw
TRANSFORMERS_CACHE=.model_cache
